		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1781772810713</Id>
			<Name><![CDATA[Robot]]></Name>
			<AdditionalClassCode><![CDATA[// ============================================================================
// Coordinate and Movement Helpers
// ============================================================================

double clampX(double x) {
    return Math.max(250, Math.min(x, 710));
}

double clampY(double y) {
    return Math.max(120, Math.min(y, 370));
}

double safeSpeed() {
    if (main.p_robotSpeed <= 0 || Double.isNaN(main.p_robotSpeed) || Double.isInfinite(main.p_robotSpeed)) {
        return 2.0;
    }
    return main.p_robotSpeed;
}

double distanceToCoords(double x, double y) {
    double dx = getX() - x;
    double dy = getY() - y;
    return Math.sqrt(dx * dx + dy * dy);
}

boolean isIdle() {
    return currentTask == null;
}

boolean hasValidTarget() {
    return !Double.isNaN(targetX)
        && !Double.isNaN(targetY)
        && !Double.isInfinite(targetX)
        && !Double.isInfinite(targetY);
}

public int getPriorityValueFallback() {
    if (currentTask != null) {
        return currentTask.getPriorityValue();
    }
    return 0;
}

public int chargingIndex() {
    ArrayList stList = (ArrayList) main.stations;
    return stList.size() - 1;
}


// ============================================================================
// Robot-specific Offsets
// ============================================================================

public double robotOffsetX() {
    // Smart Auction mode uses wider virtual station slots to reduce clustering.
    if (main.p_allocationMode == 2) {
        if (id % 5 == 0) return -22;
        if (id % 5 == 1) return 22;
        if (id % 5 == 2) return -16;
        if (id % 5 == 3) return 16;
        return 0;
    }

    // Normal modes use smaller offsets.
    if (id % 5 == 0) return -12;
    if (id % 5 == 1) return 12;
    if (id % 5 == 2) return -8;
    if (id % 5 == 3) return 8;
    return 0;
}

public double robotOffsetY() {
    // Smart Auction mode uses wider virtual station slots to reduce clustering.
    if (main.p_allocationMode == 2) {
        if (id % 5 == 0) return -16;
        if (id % 5 == 1) return -16;
        if (id % 5 == 2) return 16;
        if (id % 5 == 3) return 16;
        return 0;
    }

    // Normal modes use smaller offsets.
    if (id % 5 == 0) return -8;
    if (id % 5 == 1) return -8;
    if (id % 5 == 2) return 8;
    if (id % 5 == 3) return 8;
    return 0;
}

public boolean isNearAnyStation(double radius) {
    if (main.stations == null) return false;

    ArrayList stList = (ArrayList) main.stations;

    for (int i = 0; i < stList.size(); i++) {
        double[] s = (double[]) stList.get(i);

        double dx = getX() - s[0];
        double dy = getY() - s[1];
        double d = Math.sqrt(dx * dx + dy * dy);

        if (d <= radius) {
            return true;
        }
    }

    return false;
}

public boolean isNearChargingStation(double radius) {
    ArrayList stList = (ArrayList) main.stations;
    double[] charger = (double[]) stList.get(chargingIndex());

    double dx = getX() - charger[0];
    double dy = getY() - charger[1];
    double d = Math.sqrt(dx * dx + dy * dy);

    return d <= radius;
}

public boolean isActivelyTravelling() {
    if (currentTask == null && !wantsCharging) return false;
    if (!hasValidTarget()) return false;

    double d = distanceToCoords(targetX, targetY);

    if (Double.isNaN(d) || Double.isInfinite(d)) return false;

    return d > 30;
}


// ============================================================================
// Battery-aware Task Estimation
// ============================================================================

public double estimateTaskDistance(Task t) {
    if (t == null) return 999999;

    double d1 = distanceToCoords(t.pickupX, t.pickupY);

    double dx2 = t.pickupX - t.dropoffX;
    double dy2 = t.pickupY - t.dropoffY;
    double d2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);

    ArrayList stList = (ArrayList) main.stations;
    double[] charger = (double[]) stList.get(chargingIndex());

    double dx3 = t.dropoffX - charger[0];
    double dy3 = t.dropoffY - charger[1];
    double d3 = Math.sqrt(dx3 * dx3 + dy3 * dy3);

    return d1 + d2 + d3;
}

public double directTaskTravelDistance(Task t) {
    if (t == null) return 999999;

    double pickupDist = distanceToCoords(t.pickupX, t.pickupY);

    double dx = t.pickupX - t.dropoffX;
    double dy = t.pickupY - t.dropoffY;
    double deliveryDist = Math.sqrt(dx * dx + dy * dy);

    return pickupDist + deliveryDist;
}

public boolean hasEnoughBatteryFor(Task t) {
    if (t == null) return false;

    double estimatedDistance = estimateTaskDistance(t);
    double requiredBattery = estimatedDistance / 75.0;

    return batteryLevel >= requiredBattery + 8.0;
}


// ============================================================================
// Mode 1 Utility Score: AI heuristic
// ============================================================================

public double evaluateTask(Task t) {
    if (t == null) return -999999;

    if (wantsCharging && batteryLevel < 40.0) {
        return -999999;
    }

    if (!hasEnoughBatteryFor(t)) {
        return -999999;
    }

    double totalTravel = directTaskTravelDistance(t);

    // Utility sees speed, but not as aggressively as the smart coordinator.
    double speedScore = 1000.0 / (totalTravel + 1.0);

    double estimatedDistance = estimateTaskDistance(t);
    double estimatedBatteryNeed = estimatedDistance / 75.0;
    double reserve = batteryLevel - estimatedBatteryNeed;

    if (reserve < 8.0) {
        return -999999;
    }

    double reserveScore = reserve / 100.0;
    double priorityScore = t.getPriorityValue() / 3.0;
    double workloadScore = 1.0 / (tasksCompleted + 1.0);

    /*
    Mode 1 = heuristic AI:
    distance/speed + priority + battery reserve + workload.
    */
    return 0.40 * speedScore
         + 0.30 * priorityScore
         + 0.20 * reserveScore
         + 0.10 * workloadScore;
}


// ============================================================================
// Mode 2 Auction Bid: priority-aware + RL-assisted
// ============================================================================

public double rlWorkConfidence() {
    int s = getRLState();

    double qWork = qTable[s][0];
    double qCharge = qTable[s][1];

    return qWork - qCharge;
}

public double evaluateAuctionBid(Task t) {
    if (t == null) return -999999;

    if (batteryLevel < 22.0) {
        return -999999;
    }

    if (wantsCharging && batteryLevel < 35.0) {
        return -999999;
    }

    if (!hasEnoughBatteryFor(t)) {
        return -999999;
    }

    double totalTravel = directTaskTravelDistance(t);
    double speedScore = 1000.0 / (totalTravel + 1.0);

    int p = t.getPriorityValue();

    double priorityScore;
    if (p <= 1) {
        priorityScore = 0.3;
    } else if (p == 2) {
        priorityScore = 1.5;
    } else {
        priorityScore = 5.0;
    }

    double estimatedDistance = estimateTaskDistance(t);
    double estimatedBatteryNeed = estimatedDistance / 75.0;
    double reserve = batteryLevel - estimatedBatteryNeed;

    if (reserve < 8.0) {
        return -999999;
    }

    double reserveScore = reserve / 100.0;
    double workloadScore = 1.0 / (tasksCompleted + 1.0);

    ArrayList pList = (ArrayList) main.pendingTasks;
    double queuePressure = Math.min(1.0, pList.size() / 10.0);

    double ageScore = Math.min(1.0, (time() - t.createdAt) / 20.0);
    double rlScore = Math.tanh(rlWorkConfidence() / 100.0);

    return 0.35 * speedScore
         + 0.35 * priorityScore
         + 0.10 * reserveScore
         + 0.07 * workloadScore
         + 0.06 * queuePressure
         + 0.04 * ageScore
         + 0.03 * rlScore;
}


// ============================================================================
// Task Assignment
// ============================================================================

public void assignTask(Task t) {
    if (t == null) return;
    if (!isIdle()) return;

    currentTask = t;
    currentTask.assigned = true;
    currentTask.status = "EN_ROUTE_PICKUP";

    isPickedUp = false;
    wantsCharging = false;

    targetX = clampX(t.pickupX + robotOffsetX());
    targetY = clampY(t.pickupY + robotOffsetY());

    traceln("[t=" + (int) time() + "] Robot " + id
        + " ASSIGNED " + currentTask);
}


// ============================================================================
// Pickup and Dropoff Movement
// ============================================================================

public void startMovingToPickup() {
    if (currentTask == null) return;

    currentTask.status = "EN_ROUTE_PICKUP";

    targetX = clampX(currentTask.pickupX + robotOffsetX());
    targetY = clampY(currentTask.pickupY + robotOffsetY());

    if (!hasValidTarget()) return;

    setSpeed(safeSpeed());
    moveTo(targetX, targetY);

    traceln("[t=" + (int) time() + "] Robot " + id
        + " STARTED travelling to pickup location " + (currentTask.pickupIndex + 1)
        + " for Task#" + currentTask.id
        + " target=(" + (int) targetX + "," + (int) targetY + ")");
}

public void doPickup() {
    if (currentTask == null) return;
    if (isPickedUp) return;

    double d = distanceToCoords(currentTask.pickupX, currentTask.pickupY);

    if (Double.isNaN(d) || Double.isInfinite(d)) return;

    if (d > 35) {
        traceln("WARNING: Robot " + id
            + " tried pickup too early. Distance to pickup = "
            + String.format("%.1f", d));
        return;
    }

    isPickedUp = true;
    currentTask.status = "PICKED_UP";

    targetX = clampX(currentTask.dropoffX + robotOffsetX());
    targetY = clampY(currentTask.dropoffY + robotOffsetY());

    traceln("[t=" + (int) time() + "] Robot " + id
        + " PICKED UP Task#" + currentTask.id
        + " at location " + (currentTask.pickupIndex + 1));
}

public void startMovingToDropoff() {
    if (currentTask == null) return;
    if (!isPickedUp) return;

    currentTask.status = "EN_ROUTE_DROPOFF";

    targetX = clampX(currentTask.dropoffX + robotOffsetX());
    targetY = clampY(currentTask.dropoffY + robotOffsetY());

    if (!hasValidTarget()) return;

    setSpeed(safeSpeed());
    moveTo(targetX, targetY);

    traceln("[t=" + (int) time() + "] Robot " + id
        + " STARTED travelling to dropoff location " + (currentTask.dropoffIndex + 1)
        + " for Task#" + currentTask.id
        + " target=(" + (int) targetX + "," + (int) targetY + ")");
}

public void doDropoff() {
    if (currentTask == null) return;
    if (!isPickedUp) return;

    double d = distanceToCoords(currentTask.dropoffX, currentTask.dropoffY);

    if (Double.isNaN(d) || Double.isInfinite(d)) return;

    if (d > 35) {
        traceln("WARNING: Robot " + id
            + " tried dropoff too early. Distance to dropoff = "
            + String.format("%.1f", d));
        return;
    }

    double completionTime = time() - currentTask.createdAt;

    currentTask.completedAt = time();
    currentTask.status = "COMPLETED";

    main.recordCompletedTask(currentTask, completionTime);

    batteryLevel -= 15.0 + uniform(0, 8);
    if (batteryLevel < 0) batteryLevel = 0;

    rewardAfterDelivery(completionTime);

    tasksCompleted++;

    traceln("[t=" + (int) time() + "] Robot " + id
        + " DELIVERED Task#" + currentTask.id
        + " at dropoff location " + (currentTask.dropoffIndex + 1)
        + " | completed in " + String.format("%.1f", completionTime)
        + "s | batt=" + (int) batteryLevel + "%");

    traceln("Robot " + id + " battery after delivery: "
        + (int) batteryLevel + "%");

    currentTask = null;
    isPickedUp = false;

    main.onRobotIdle(this);
}


// ============================================================================
// Charging
// ============================================================================

public void startCharging() {
    ArrayList stList = (ArrayList) main.stations;

    double[] charger = (double[]) stList.get(chargingIndex());

    targetX = clampX(charger[0] + robotOffsetX());
    targetY = clampY(charger[1] + robotOffsetY());

    if (!hasValidTarget()) return;

    setSpeed(safeSpeed());
    moveTo(targetX, targetY);

    traceln("[t=" + (int) time() + "] Robot " + id
        + " travelling to YELLOW charging station");
}

public void recharge() {
    if (!isNearChargingStation(40)) {
        return;
    }

    batteryLevel = Math.min(100.0, batteryLevel + 5.0);

    traceln("[t=" + (int) time() + "] Robot " + id
        + " charging: " + (int) batteryLevel + "%");
}


// ============================================================================
// Battery Drain
// ============================================================================

public void drainBatteryWhileMoving() {
    if (currentTask != null || (wantsCharging && !isNearChargingStation(40))) {
        batteryLevel -= 0.01;
        if (batteryLevel < 0) batteryLevel = 0;
    }
}


// ============================================================================
// Safe Collision Risk Monitoring
// ============================================================================

public void avoidCollisionSafe() {
    if (!isActivelyTravelling()) return;

    // Do not count station clustering as corridor collision risk.
    if (isNearAnyStation(65)) return;

    for (int i = 0; i < main.robots.size(); i++) {
        Robot other = (Robot) main.robots.get(i);

        if (other == this) continue;
        if (id > other.id) continue;

        if (!other.isActivelyTravelling()) continue;
        if (other.isNearAnyStation(65)) continue;

        double dx = getX() - other.getX();
        double dy = getY() - other.getY();
        double d = Math.sqrt(dx * dx + dy * dy);

        if (Double.isNaN(d) || Double.isInfinite(d)) continue;

        // Only count genuine moving-corridor conflicts.
        if (d < main.p_safetyRadius) {
            if (time() - lastCollisionRiskTime >= 4.0) {
                main.recordCollisionRisk();
                lastCollisionRiskTime = time();

                traceln("[t=" + (int) time()
                    + "] Collision risk in moving corridor between Robot "
                    + id + " and Robot " + other.id
                    + " | distance=" + String.format("%.1f", d));
            }
        }
    }
}

public void resumeMovement() {
    isYielding = false;
}


// ============================================================================
// Tabular Q-Learning Charging Policy
// ============================================================================

public int batteryBucket() {
    if (batteryLevel < 30) return 0;
    if (batteryLevel < 60) return 1;
    return 2;
}

public int taskLoadBucket() {
    ArrayList pList = (ArrayList) main.pendingTasks;
    if (pList == null) return 0;

    if (pList.size() >= 4) return 1;
    return 0;
}

public int nearestTaskDistanceBucket() {
    ArrayList pList = (ArrayList) main.pendingTasks;
    if (pList == null || pList.isEmpty()) return 2;

    double best = Double.MAX_VALUE;

    for (int i = 0; i < pList.size(); i++) {
        Task t = (Task) pList.get(i);
        if (t == null || t.assigned) continue;

        double d = distanceToCoords(t.pickupX, t.pickupY);
        if (d < best) best = d;
    }

    if (best == Double.MAX_VALUE) return 2;
    if (best < 220) return 0;
    return 1;
}

public int getRLState() {
    int b = batteryBucket();
    int l = taskLoadBucket();
    int d = nearestTaskDistanceBucket();

    return b * 6 + l * 3 + d;
}

public int chooseRLAction(int state) {
    if (batteryLevel < 25.0) {
        return 1;
    }

    if (batteryLevel > 45.0) {
        return 0;
    }

    if (uniform(0, 1) < epsilon) {
        return (int) uniform(0, 2);
    }

    if (qTable[state][1] > qTable[state][0]) {
        return 1;
    }

    return 0;
}

public void updateQ(int newState, double reward) {
    if (!hasLastAction) return;

    double oldQ = qTable[lastState][lastAction];
    double maxFutureQ = Math.max(qTable[newState][0], qTable[newState][1]);

    qTable[lastState][lastAction] =
        oldQ + alpha * (reward + gamma * maxFutureQ - oldQ);
}

public void decideChargingOrWorkRL() {
    if (currentTask != null) return;

    int state = getRLState();
    int action = chooseRLAction(state);

    lastState = state;
    lastAction = action;
    hasLastAction = true;

    wantsCharging = action == 1;

    traceln("[RL] Robot " + id
        + " state=" + state
        + " action=" + (action == 1 ? "CHARGE" : "WORK")
        + " battery=" + String.format("%.1f", batteryLevel));
}

public void rewardAfterDelivery(double completionTime) {
    int newState = getRLState();

    double reward = 0.0;

    if (currentTask != null) {
        int p = currentTask.getPriorityValue();

        double targetTime;
        if (p <= 1) {
            targetTime = 14.0;
        } else if (p == 2) {
            targetTime = 10.0;
        } else {
            targetTime = 7.0;
        }

        double baseReward;
        if (p <= 1) {
            baseReward = 20.0;
        } else if (p == 2) {
            baseReward = 60.0;
        } else {
            baseReward = 150.0;
        }

        reward = baseReward;
        reward += Math.max(0.0, targetTime - completionTime) * p * 8.0;
        reward -= Math.max(0.0, completionTime - targetTime) * p * 5.0;
    }

    if (batteryLevel < 15.0) {
        reward -= 80.0;
    }

    updateQ(newState, reward);

    traceln("[RL] Robot " + id
        + " delivery reward=" + String.format("%.2f", reward)
        + " Q-work=" + String.format("%.2f", qTable[newState][0])
        + " Q-charge=" + String.format("%.2f", qTable[newState][1]));
}

public void rewardAfterCharging() {
    int newState = getRLState();

    double reward = 20.0;

    if (batteryLevel >= 95.0) {
        reward += 20.0;
    }

    reward -= 5.0;

    updateQ(newState, reward);

    wantsCharging = false;

    traceln("[RL] Robot " + id
        + " charging reward=" + String.format("%.2f", reward)
        + " Q-work=" + String.format("%.2f", qTable[newState][0])
        + " Q-charge=" + String.format("%.2f", qTable[newState][1]));
}]]></AdditionalClassCode>
			<Generic>false</Generic>
			<GenericParameter>
				<Id>1781772810718</Id>
				<Name><![CDATA[1781772810718]]></Name>
				<GenericParameterValue Class="CodeValue">
					<Code><![CDATA[T extends Agent]]></Code>
				</GenericParameterValue>
				<GenericParameterLabel><![CDATA[Generic parameter:]]></GenericParameterLabel>
			</GenericParameter>
			<FlowChartsUsage>ENTITY</FlowChartsUsage>
			<SamplesToKeep>100</SamplesToKeep>
			<LimitNumberOfArrayElements>false</LimitNumberOfArrayElements>
			<ElementsLimitValue>100</ElementsLimitValue>
			<MakeDefaultViewArea>true</MakeDefaultViewArea>
			<SceneGridColor/>
			<SceneBackgroundColor>-4144960</SceneBackgroundColor>
			<SceneSkybox>null</SceneSkybox>
			<AgentProperties>
				<EnvironmentDefinesInitialLocation>true</EnvironmentDefinesInitialLocation>
				<RotateAnimationTowardsMovement>true</RotateAnimationTowardsMovement>
				<RotateAnimationVertically>false</RotateAnimationVertically>
				<VelocityCode Class="CodeUnitValue">
