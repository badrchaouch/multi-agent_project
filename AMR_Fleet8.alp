			<Events>
				<Event>
					<Id>1781788315160</Id>
					<Name><![CDATA[onStartup]]></Name>
					<ExcludeFromBuild>true</ExcludeFromBuild>
					<X>450</X><Y>700</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1781788315158</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1781856000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[ArrayList stList = new ArrayList();

// RED pickup stations inside warehouse
stList.add(new double[]{270, 155});  // W1
stList.add(new double[]{270, 245});  // W2
stList.add(new double[]{270, 335});  // W3

// GREEN dropoff stations inside warehouse
stList.add(new double[]{690, 155});  // D1
stList.add(new double[]{690, 245});  // D2
stList.add(new double[]{690, 335});  // D3

// YELLOW charging station center
// Charging node: X=420, Y=290, Width=120, Height=100
// Center = 480,340
stList.add(new double[]{480, 340});

stations = stList;
pendingTasks = new ArrayList();
auctionBids = new HashMap();

pickupActive[0] = 0;
pickupActive[1] = 0;
pickupActive[2] = 0;

int n = robots.size();

for (int i = 0; i < n; i++) {
    Robot r = (Robot) robots.get(i);

    r.id = i;
    r.batteryLevel = 100.0;
    r.currentTask = null;
    r.isPickedUp = false;
    r.isYielding = false;
    r.tasksCompleted = 0;

    double spawnX;
    double spawnY;

    if (i == 0) { spawnX = 445; spawnY = 320; }
    else if (i == 1) { spawnX = 480; spawnY = 320; }
    else if (i == 2) { spawnX = 515; spawnY = 320; }
    else if (i == 3) { spawnX = 460; spawnY = 360; }
    else { spawnX = 500; spawnY = 360; }

    r.jumpTo(spawnX, spawnY);
    r.targetX = spawnX;
    r.targetY = spawnY;
    r.setSpeed(p_robotSpeed);

    traceln("Robot " + i + " spawned near charging station at ("
        + (int)spawnX + ", " + (int)spawnY + ")");
}]]></Action>
				</Event>
				<Event>
					<Id>1781788361043</Id>
					<Name><![CDATA[taskGenerator]]></Name>
					<X>450</X><Y>730</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="rate" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[p_taskRate]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1781788361041</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1781856000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!simulationStarted) return;
if (taskIdCounter >= p_maxTasks) {
    return;
}

ArrayList stList = (ArrayList) stations;

// Deterministic task sequence for fair comparison across modes.
// Every allocation mode receives the same task pattern.
int taskSeq = taskIdCounter;
int scenario = taskSeq % 10;

int lane = taskSeq % 3;
int destLane = (taskSeq + 1) % 3;

int sourceIndex = 0;
int destIndex = 6;
int priority = 2;

String sourceName = "";
String destName = "";
String taskType = "";

/*
Scenario distribution per 10 tasks:
0,1,2 = Emergency priority 3
3,4,5,6 = Medium priority 2
7,8,9 = Low priority 1
*/

if (scenario == 0) {
    // Emergency Pharmacy → Ward A
    sourceIndex = lane;
    destIndex = 6 + destLane;
    priority = 3;
    sourceName = "Pharmacy";
    destName = "Ward A";
    taskType = "Emergency medicine";

} else if (scenario == 1) {
    // Emergency Pharmacy → Ward B
    sourceIndex = lane;
    destIndex = 9 + destLane;
    priority = 3;
    sourceName = "Pharmacy";
    destName = "Ward B";
    taskType = "Emergency medicine";

} else if (scenario == 2) {
    // Emergency Ward A/B → Lab
    if (taskSeq % 2 == 0) {
        sourceIndex = 6 + lane;
    } else {
        sourceIndex = 9 + lane;
    }

    destIndex = 3 + destLane;
    priority = 3;
    sourceName = stationGroupName(sourceIndex);
    destName = "Lab";
    taskType = "Emergency sample delivery";

} else if (scenario == 3) {
    // Medium Pharmacy → Ward A
    sourceIndex = lane;
    destIndex = 6 + destLane;
    priority = 2;
    sourceName = "Pharmacy";
    destName = "Ward A";
    taskType = "Medicine delivery";

} else if (scenario == 4) {
    // Medium Pharmacy → Ward B
    sourceIndex = lane;
    destIndex = 9 + destLane;
    priority = 2;
    sourceName = "Pharmacy";
    destName = "Ward B";
    taskType = "Medicine delivery";

} else if (scenario == 5) {
    // Medium Ward A → Lab
    sourceIndex = 6 + lane;
    destIndex = 3 + destLane;
    priority = 2;
    sourceName = "Ward A";
    destName = "Lab";
    taskType = "Blood sample delivery";

} else if (scenario == 6) {
    // Medium Ward B → Lab
    sourceIndex = 9 + lane;
    destIndex = 3 + destLane;
    priority = 2;
    sourceName = "Ward B";
    destName = "Lab";
    taskType = "Blood sample delivery";

} else if (scenario == 7) {
    // Low Lab → Ward A
    sourceIndex = 3 + lane;
    destIndex = 6 + destLane;
    priority = 1;
    sourceName = "Lab";
    destName = "Ward A";
    taskType = "Lab result delivery";

} else if (scenario == 8) {
    // Low Lab → Ward B
    sourceIndex = 3 + lane;
    destIndex = 9 + destLane;
    priority = 1;
    sourceName = "Lab";
    destName = "Ward B";
    taskType = "Lab result delivery";

} else {
    // Low Ward → Pharmacy return / supply request
    if (taskSeq % 2 == 0) {
        sourceIndex = 6 + lane;
        sourceName = "Ward A";
    } else {
        sourceIndex = 9 + lane;
        sourceName = "Ward B";
    }

    destIndex = destLane;
    priority = 1;
    destName = "Pharmacy";
    taskType = "Routine supply request";
}

double[] source = (double[]) stList.get(sourceIndex);
double[] dest = (double[]) stList.get(destIndex);

Task t = new Task(
    taskIdCounter++,
    sourceName + " - " + taskType,
    source[0],
    source[1],
    destName,
    dest[0],
    dest[1],
    priority,
    sourceIndex,
    destIndex,
    time()
);

ArrayList pList = (ArrayList) pendingTasks;
pList.add(t);

traceln("[t=" + (int) time() + "] CREATED " + t
    + " | priority=" + t.getPriorityName()
    + " | route=" + stationName(sourceIndex) + " -> " + stationName(destIndex));

allocateTask(t);]]></Action>
				</Event>
			</Events>
