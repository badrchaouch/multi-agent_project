			<AdditionalClassCode><![CDATA[public static final int NEAREST = 0;
public static final int UTILITY = 1;
public static final int AUCTION = 2;

// ============================================================================
// KPI TRACKING
// ============================================================================

public double customTotalCompletionTime = 0.0;
public int customCompletedTaskSamples = 0;
public int customCollisionRiskCount = 0;

// Priority / smart-system scoring
public double totalPriorityScore = 0.0;
public double totalWeightedCompletionTime = 0.0;
public double totalPriorityWeight = 0.0;

public double highPriorityTotalTime = 0.0;
public int highPriorityCompleted = 0;

public int lowPriorityCompleted = 0;
public int mediumPriorityCompleted = 0;
public int emergencyPriorityCompleted = 0;

// Station capacity counter.
// 13 hospital stations:
// 0-2 Pharmacy, 3-5 Lab, 6-8 Ward A, 9-11 Ward B, 12 Charging.
public int[] pickupActive = new int[13];


// ============================================================================
// KPI AND SCORING FUNCTIONS
// ============================================================================

public void recordCompletionTime(double completionTime) {
    customTotalCompletionTime += completionTime;
    customCompletedTaskSamples++;
    totalTasksCompleted++;

    if (completionTimes != null) {
        ArrayList list = (ArrayList) completionTimes;
        list.add(completionTime);
    }
}

public void recordCompletedTask(Task t, double completionTime) {
    if (t == null) {
        recordCompletionTime(completionTime);
        return;
    }

    recordCompletionTime(completionTime);
    releasePickupSlot(t);

    int p = t.getPriorityValue();

    if (p <= 1) {
        lowPriorityCompleted++;
    } else if (p == 2) {
        mediumPriorityCompleted++;
    } else {
        emergencyPriorityCompleted++;
        highPriorityCompleted++;
        highPriorityTotalTime += completionTime;
    }

    totalPriorityWeight += p;
    totalWeightedCompletionTime += completionTime * p;

    double points = priorityPoints(t, completionTime);
    totalPriorityScore += points;

    traceln("[SCORE] Task " + t.id
        + " priority=" + t.getPriorityName()
        + " completion=" + String.format("%.2f", completionTime)
        + " points=" + String.format("%.1f", points)
        + " totalScore=" + String.format("%.1f", totalPriorityScore));
}

public double priorityPoints(Task t, double completionTime) {
    if (t == null) return 0.0;

    int p = t.getPriorityValue();

    double basePoints;
    double targetTime;
    double earlyMultiplier;
    double lateMultiplier;

    if (p <= 1) {
        // Routine task
        basePoints = 20.0;
        targetTime = 22.0;
        earlyMultiplier = 1.5;
        lateMultiplier = 1.0;

    } else if (p == 2) {
        // Medium task
        basePoints = 80.0;
        targetTime = 18.0;
        earlyMultiplier = 4.0;
        lateMultiplier = 3.0;

    } else {
        // Emergency task
        basePoints = 220.0;
        targetTime = 14.0;
        earlyMultiplier = 8.0;
        lateMultiplier = 6.0;
    }

    double earlyBonus = Math.max(0.0, targetTime - completionTime) * p * earlyMultiplier;
    double latePenalty = Math.max(0.0, completionTime - targetTime) * p * lateMultiplier;

    double score = basePoints + earlyBonus - latePenalty;

    if (score < 0.0) score = 0.0;

    return score;
}

public double avgCompletionTime() {
    if (customCompletedTaskSamples == 0) return 0.0;
    return customTotalCompletionTime / customCompletedTaskSamples;
}

public double avgPriorityWeightedCompletionTime() {
    if (totalPriorityWeight <= 0.0) return 0.0;
    return totalWeightedCompletionTime / totalPriorityWeight;
}

public double avgHighPriorityCompletionTime() {
    if (highPriorityCompleted == 0) return 0.0;
    return highPriorityTotalTime / highPriorityCompleted;
}

public double avgScorePerTask() {
    if (totalTasksCompleted == 0) return 0.0;
    return totalPriorityScore / totalTasksCompleted;
}

public void recordCollisionRisk() {
    customCollisionRiskCount++;
}

public int totalCollisionRisks() {
    return customCollisionRiskCount;
}

public int pendingTaskCount() {
    if (pendingTasks == null) return 0;

    ArrayList pList = (ArrayList) pendingTasks;
    return pList.size();
}


// ============================================================================
// STATION NAME HELPERS
// ============================================================================

public String stationName(int index) {
    if (index == 0) return "Pharmacy 1";
    if (index == 1) return "Pharmacy 2";
    if (index == 2) return "Pharmacy 3";

    if (index == 3) return "Lab 1";
    if (index == 4) return "Lab 2";
    if (index == 5) return "Lab 3";

    if (index == 6) return "Ward A1";
    if (index == 7) return "Ward A2";
    if (index == 8) return "Ward A3";

    if (index == 9) return "Ward B1";
    if (index == 10) return "Ward B2";
    if (index == 11) return "Ward B3";

    if (index == 12) return "Charging";

    return "Unknown";
}

public String stationGroupName(int index) {
    if (index >= 0 && index <= 2) return "Pharmacy";
    if (index >= 3 && index <= 5) return "Lab";
    if (index >= 6 && index <= 8) return "Ward A";
    if (index >= 9 && index <= 11) return "Ward B";
    if (index == 12) return "Charging";
    return "Unknown";
}

public String allocationModeName() {
    if (p_allocationMode == NEAREST) return "NEAREST";
    if (p_allocationMode == UTILITY) return "UTILITY";
    return "SMART AUCTION + RL";
}


// ============================================================================
// STATION CAPACITY / QUEUE LOGIC
// ============================================================================

public boolean canUsePickup(Task t) {
    if (t == null) return false;
    if (t.pickupIndex < 0 || t.pickupIndex >= pickupActive.length) return false;

    return pickupActive[t.pickupIndex] < 2;
}

public void reservePickupSlot(Task t) {
    if (t == null) return;
    if (t.pickupIndex < 0 || t.pickupIndex >= pickupActive.length) return;

    pickupActive[t.pickupIndex]++;
}

public void releasePickupSlot(Task t) {
    if (t == null) return;
    if (t.pickupIndex < 0 || t.pickupIndex >= pickupActive.length) return;

    pickupActive[t.pickupIndex]--;

    if (pickupActive[t.pickupIndex] < 0) {
        pickupActive[t.pickupIndex] = 0;
    }
}


// ============================================================================
// TASK ALLOCATION CONTROLLER
// Main acts as Coordinator / Task Manager.
// ============================================================================

public void allocateTask(Task t) {
    if (t == null) return;

    switch (p_allocationMode) {
        case NEAREST:
            allocateNearest(t);
            break;

        case UTILITY:
            allocateUtility(t);
            break;

        case AUCTION:
            startAuction(t);
            break;

        default:
            startAuction(t);
            break;
    }
}

public void assignRobotToTask(Robot r, Task t, String modeName) {
    if (r == null || t == null) return;
    if (!r.isIdle()) return;
    if (r.batteryLevel <= p_batteryThreshold) return;
    if (!canUsePickup(t)) return;

    ArrayList pList = (ArrayList) pendingTasks;
    pList.remove(t);

    reservePickupSlot(t);
    r.assignTask(t);

    traceln("[" + modeName + "] Task " + t.id
        + " -> Robot " + r.id
        + " | " + stationName(t.pickupIndex)
        + " active=" + pickupActive[t.pickupIndex]);
}


// ============================================================================
// MODE 0: NEAREST ROBOT
// Baseline: fastest/simple, but does not reason about priority or congestion.
// ============================================================================

public void allocateNearest(Task t) {
    Robot best = null;
    double bestDist = Double.MAX_VALUE;

    if (!canUsePickup(t)) {
        ArrayList pList = (ArrayList) pendingTasks;
        if (!pList.contains(t)) pList.add(t);

        traceln("[NEAREST] Source station full, Task " + t.id + " queued");
        return;
    }

    for (int i = 0; i < robots.size(); i++) {
        Robot r = (Robot) robots.get(i);

        if (!r.isIdle()) continue;
        if (r.batteryLevel <= p_batteryThreshold) continue;
        if (r.wantsCharging) continue;
        if (!r.hasEnoughBatteryFor(t)) continue;

        double dx = r.getX() - t.pickupX;
        double dy = r.getY() - t.pickupY;
        double d = Math.sqrt(dx * dx + dy * dy);

        if (d < bestDist) {
            bestDist = d;
            best = r;
        }
    }

    if (best != null) {
        assignRobotToTask(best, t, "NEAREST");
    } else {
        ArrayList pList = (ArrayList) pendingTasks;
        if (!pList.contains(t)) pList.add(t);

        traceln("[NEAREST] No eligible robot, Task " + t.id + " queued");
    }
}


// ============================================================================
// MODE 1: UTILITY AI
// Balanced heuristic: speed + priority + battery reserve + workload.
// ============================================================================

public void allocateUtility(Task t) {
    Robot best = null;
    double bestScore = Double.NEGATIVE_INFINITY;

    if (!canUsePickup(t)) {
        ArrayList pList = (ArrayList) pendingTasks;
        if (!pList.contains(t)) pList.add(t);

        traceln("[UTILITY] Source station full, Task " + t.id + " queued");
        return;
    }

    for (int i = 0; i < robots.size(); i++) {
        Robot r = (Robot) robots.get(i);

        if (!r.isIdle()) continue;
        if (r.batteryLevel <= p_batteryThreshold) continue;

        double score = r.evaluateTask(t);

        if (score > bestScore) {
            bestScore = score;
            best = r;
        }
    }

    if (best != null && bestScore > -999998) {
        assignRobotToTask(best, t, "UTILITY");
    } else {
        ArrayList pList = (ArrayList) pendingTasks;
        if (!pList.contains(t)) pList.add(t);

        traceln("[UTILITY] No eligible robot, Task " + t.id + " queued");
    }
}


// ============================================================================
// MODE 2: SMART COORDINATOR / AUCTION + RL
// Priority-first + fastest feasible robot + congestion-aware dispatch.
// ============================================================================

public void startAuction(Task t) {
    ArrayList pList = (ArrayList) pendingTasks;

    if (t != null && !pList.contains(t) && !t.assigned) {
        pList.add(t);
    }

    traceln("[SMART-AUCTION] Coordinator scanning pending tasks and idle robots");

    smartCoordinatorDispatch();
}

public double smartDispatchCost(Robot r, Task t) {
    if (r == null || t == null) return Double.MAX_VALUE;

    if (!r.isIdle()) return Double.MAX_VALUE;
    if (r.batteryLevel <= p_batteryThreshold) return Double.MAX_VALUE;
    if (!canUsePickup(t)) return Double.MAX_VALUE;
    if (!r.hasEnoughBatteryFor(t)) return Double.MAX_VALUE;

    if (r.wantsCharging && r.batteryLevel < 35.0) {
        return Double.MAX_VALUE;
    }

    double travelDistance = r.directTaskTravelDistance(t);
    double speed = Math.max(1.0, p_robotSpeed);
    double predictedTravelTime = travelDistance / speed;

    double waitingTime = Math.max(0.0, time() - t.createdAt);
    int p = t.getPriorityValue();

    /*
    Final Mode 2 behaviour:
    - emergency tasks should be served fastest
    - medium/low tasks should avoid congestion strongly
    - smart mode should use spatial coordination
    */

    double priorityPenalty;

    if (p >= 3) {
        priorityPenalty = 0.0;       // Emergency first
    } else if (p == 2) {
        priorityPenalty = 130.0;     // Medium after emergency
    } else {
        priorityPenalty = 280.0;     // Low last
    }

    // Emergency: prioritize travel time strongly.
    // Medium/low: care more about congestion and smooth routing.
    double travelWeight;
    if (p >= 3) {
        travelWeight = 1.00;
    } else if (p == 2) {
        travelWeight = 0.95;
    } else {
        travelWeight = 0.90;
    }

    double congestionPenalty = smartCongestionPenalty(r, t);

    double congestionWeight;
    if (p >= 3) {
        congestionWeight = 0.35;     // Do not slow emergency too much
    } else if (p == 2) {
        congestionWeight = 1.50;
    } else {
        congestionWeight = 1.80;
    }

    double waitingBonus = Math.min(50.0, waitingTime * p * 1.0);

    double batteryPenalty = (100.0 - r.batteryLevel) * 0.020;
    double workloadPenalty = r.tasksCompleted * 0.050;

    double rlBonus = Math.tanh(r.rlWorkConfidence() / 100.0) * 2.0;

    return priorityPenalty
        + travelWeight * predictedTravelTime
        + congestionWeight * congestionPenalty
        + batteryPenalty
        + workloadPenalty
        - waitingBonus
        - rlBonus;
}

public double smartCongestionPenalty(Robot candidate, Task t) {
    if (candidate == null || t == null) return 0.0;

    double penalty = 0.0;

    double cStartX = candidate.getX();
    double cStartY = candidate.getY();

    double cPickupX = t.pickupX;
    double cPickupY = t.pickupY;

    double cDropX = t.dropoffX;
    double cDropY = t.dropoffY;

    for (int i = 0; i < robots.size(); i++) {
        Robot other = (Robot) robots.get(i);

        if (other == null) continue;
        if (other == candidate) continue;

        if (other.currentTask != null || other.wantsCharging) {

            // Same pickup conflict.
            if (other.currentTask != null && other.currentTask.pickupIndex == t.pickupIndex) {
                penalty += 35.0;
            }

            // Same dropoff conflict.
            if (other.currentTask != null && other.currentTask.dropoffIndex == t.dropoffIndex) {
                penalty += 30.0;
            }

            // Candidate route conflict with other robot current location.
            double d1 = pointSegmentDistance(
                other.getX(), other.getY(),
                cStartX, cStartY,
                cPickupX, cPickupY
            );

            double d2 = pointSegmentDistance(
                other.getX(), other.getY(),
                cPickupX, cPickupY,
                cDropX, cDropY
            );

            if (Math.min(d1, d2) < 70.0) {
                penalty += 25.0;
            }

            // Candidate route conflict with other robot target.
            if (!Double.isNaN(other.targetX) && !Double.isNaN(other.targetY)) {
                double d3 = pointSegmentDistance(
                    other.targetX, other.targetY,
                    cStartX, cStartY,
                    cPickupX, cPickupY
                );

                double d4 = pointSegmentDistance(
                    other.targetX, other.targetY,
                    cPickupX, cPickupY,
                    cDropX, cDropY
                );

                if (Math.min(d3, d4) < 70.0) {
                    penalty += 25.0;
                }
            }

            // Nearby destination crowding.
            if (other.currentTask != null) {
                double dxDrop = other.targetX - cDropX;
                double dyDrop = other.targetY - cDropY;
                double dropCrowd = Math.sqrt(dxDrop * dxDrop + dyDrop * dyDrop);

                if (dropCrowd < 80.0) {
                    penalty += 25.0;
                }
            }
        }
    }

    return penalty;
}

public void smartCoordinatorDispatch() {
    ArrayList pList = (ArrayList) pendingTasks;

    if (pList == null || pList.isEmpty()) return;

    boolean assignedSomething = true;

    while (assignedSomething) {
        assignedSomething = false;

        Robot bestRobot = null;
        Task bestTask = null;
        double bestCost = Double.MAX_VALUE;

        for (int i = 0; i < robots.size(); i++) {
            Robot r = (Robot) robots.get(i);

            if (r == null) continue;
            if (!r.isIdle()) continue;
            if (r.batteryLevel <= p_batteryThreshold) continue;

            if (r.wantsCharging && r.batteryLevel < 35.0) continue;

            for (int j = 0; j < pList.size(); j++) {
                Task t = (Task) pList.get(j);

                if (t == null) continue;
                if (t.assigned) continue;
                if (!canUsePickup(t)) continue;

                double cost = smartDispatchCost(r, t);

                if (cost < bestCost) {
                    bestCost = cost;
                    bestRobot = r;
                    bestTask = t;
                }
            }
        }

        if (bestRobot != null && bestTask != null && bestCost < Double.MAX_VALUE) {
            assignRobotToTask(bestRobot, bestTask, "SMART-AUCTION");
            assignedSomething = true;
        }
    }
}


// ============================================================================
// RETRY QUEUED TASKS WHEN ROBOT BECOMES IDLE
// ============================================================================

public void onRobotIdle(Robot r) {
    if (r == null) return;
    if (!r.isIdle()) return;
    if (r.batteryLevel <= p_batteryThreshold) return;
    if (r.wantsCharging) return;

    if (p_allocationMode == AUCTION) {
        smartCoordinatorDispatch();
        return;
    }

    ArrayList pList = (ArrayList) pendingTasks;

    if (pList == null || pList.isEmpty()) return;

    Task best = null;

    if (p_allocationMode == NEAREST) {
        double bestDist = Double.MAX_VALUE;

        for (int i = 0; i < pList.size(); i++) {
            Task t = (Task) pList.get(i);

            if (t == null) continue;
            if (t.assigned) continue;
            if (!canUsePickup(t)) continue;
            if (!r.hasEnoughBatteryFor(t)) continue;

            double dx = r.getX() - t.pickupX;
            double dy = r.getY() - t.pickupY;
            double d = Math.sqrt(dx * dx + dy * dy);

            if (d < bestDist) {
                bestDist = d;
                best = t;
            }
        }

    } else {
        double bestScore = Double.NEGATIVE_INFINITY;

        for (int i = 0; i < pList.size(); i++) {
            Task t = (Task) pList.get(i);

            if (t == null) continue;
            if (t.assigned) continue;
            if (!canUsePickup(t)) continue;

            double score = r.evaluateTask(t);

            if (score > bestScore) {
                bestScore = score;
                best = t;
            }
        }
    }

    if (best != null) {
        assignRobotToTask(r, best, "RETRY");
    }
}


// ============================================================================
// RL MONITOR FUNCTIONS
// ============================================================================

public double avgQWork() {
    if (robots.size() == 0) return 0.0;

    double sum = 0.0;

    for (int i = 0; i < robots.size(); i++) {
        Robot r = (Robot) robots.get(i);
        int s = r.getRLState();
        sum += r.qTable[s][0];
    }

    return sum / robots.size();
}

public double avgQCharge() {
    if (robots.size() == 0) return 0.0;

    double sum = 0.0;

    for (int i = 0; i < robots.size(); i++) {
        Robot r = (Robot) robots.get(i);
        int s = r.getRLState();
        sum += r.qTable[s][1];
    }

    return sum / robots.size();
}

public String robot0RLText() {
    if (robots.size() == 0) return "ROBOT 0 RL POLICY\nNo robots";

    Robot r = (Robot) robots.get(0);
    int s = r.getRLState();

    return "ROBOT 0 RL POLICY"
        + "\nState: " + s
        + "\nAction: " + (r.wantsCharging ? "CHARGE" : "WORK")
        + "\nBattery: " + String.format("%.1f", r.batteryLevel) + "%"
        + "\nQ-Work: " + String.format("%.2f", r.qTable[s][0])
        + "\nQ-Charge: " + String.format("%.2f", r.qTable[s][1]);
}

public String rlMonitorText() {
    return "RL MONITOR"
        + "\nAvg Q-Work: " + String.format("%.2f", avgQWork())
        + "\nAvg Q-Charge: " + String.format("%.2f", avgQCharge());
}


// ============================================================================
// LEARNING / PERFORMANCE TEXT
// ============================================================================

public String learningProgressText() {
    return "SMART PERFORMANCE"
        + "\nPriority Score: " + String.format("%.1f", totalPriorityScore)
        + "\nAvg Score/Task: " + String.format("%.1f", avgScorePerTask())
        + "\nWeighted Avg Time: " + String.format("%.2f", avgPriorityWeightedCompletionTime()) + "s"
        + "\nHigh Priority Avg: " + String.format("%.2f", avgHighPriorityCompletionTime()) + "s"
        + "\nLow/Med/Emerg: " + lowPriorityCompleted + "/"
            + mediumPriorityCompleted + "/"
            + emergencyPriorityCompleted;
}


// ============================================================================
// ROBOT STATUS PANEL
// ============================================================================

public String robotStatusText() {
    String txt = "ROBOT STATUS PANEL\n";

    for (int i = 0; i < robots.size(); i++) {
        Robot r = (Robot) robots.get(i);

        txt += "\nRobot " + r.id;
        txt += "\nBattery: " + String.format("%.1f", r.batteryLevel) + "%";

        if (r.currentTask != null) {
            txt += "\nTask: " + r.currentTask.sourceLocation;

            if (!r.isPickedUp) {
                txt += "\nGoal: Pickup at " + stationName(r.currentTask.pickupIndex);
            } else {
                txt += "\nGoal: Deliver to " + stationName(r.currentTask.dropoffIndex);
            }

            txt += "\nRoute: " + stationName(r.currentTask.pickupIndex)
                + " → " + stationName(r.currentTask.dropoffIndex);

            txt += "\nPriority: " + r.currentTask.getPriorityName();

        } else if (r.wantsCharging || r.batteryLevel < p_batteryThreshold) {
            txt += "\nTask: Charging";
            txt += "\nGoal: Charging station";

        } else {
            txt += "\nTask: Idle";
            txt += "\nGoal: Waiting for task";
        }

        txt += "\n----------------";
    }

    return txt;
}


// ============================================================================
// DASHBOARD TEXT FUNCTIONS
// ============================================================================

public String mainKPIText() {
    return "Mode: " + allocationModeName()
        + "\nTasks Done: " + totalTasksCompleted
        + "\nPending Tasks: " + pendingTaskCount()
        + "\nAvg Time: " + String.format("%.2f", avgCompletionTime()) + "s"
        + "\nPriority Score: " + String.format("%.1f", totalPriorityScore)
        + "\nCollision Risk: " + totalCollisionRisks();
}

public double pointSegmentDistance(
        double px, double py,
        double ax, double ay,
        double bx, double by) {

    double dx = bx - ax;
    double dy = by - ay;

    if (Math.abs(dx) < 0.0001 && Math.abs(dy) < 0.0001) {
        double ex = px - ax;
        double ey = py - ay;
        return Math.sqrt(ex * ex + ey * ey);
    }

    double t = ((px - ax) * dx + (py - ay) * dy) / (dx * dx + dy * dy);

    if (t < 0.0) t = 0.0;
    if (t > 1.0) t = 1.0;

    double closestX = ax + t * dx;
    double closestY = ay + t * dy;

    double ex = px - closestX;
    double ey = py - closestY;

    return Math.sqrt(ex * ex + ey * ey);
}]]></AdditionalClassCode>
			<StartupCode><![CDATA[ArrayList stList = new ArrayList();

/*
Hospital service locations:

0–2   Pharmacy points      red / left
3–5   Lab points           green / right
6–8   Ward A points        purple / top
9–11  Ward B points        pink / bottom
12    Charging station     yellow / centre
*/

// 0–2 Pharmacy points
stList.add(new double[]{270, 155});  // Pharmacy 1
stList.add(new double[]{270, 245});  // Pharmacy 2
stList.add(new double[]{270, 335});  // Pharmacy 3

// 3–5 Lab points
stList.add(new double[]{690, 155});  // Lab 1
stList.add(new double[]{690, 245});  // Lab 2
stList.add(new double[]{690, 335});  // Lab 3

// 6–8 Ward A points
stList.add(new double[]{350, 125});  // Ward A1
stList.add(new double[]{480, 125});  // Ward A2
stList.add(new double[]{610, 125});  // Ward A3

// 9–11 Ward B points
stList.add(new double[]{350, 365});  // Ward B1
stList.add(new double[]{480, 365});  // Ward B2
stList.add(new double[]{610, 365});  // Ward B3

// 12 Charging station
stList.add(new double[]{480, 245});  // Charging centre

stations = stList;
pendingTasks = new ArrayList();
auctionBids = new HashMap();

// Reset task counters
taskIdCounter = 0;
totalTasksCompleted = 0;

// Reset KPI counters
customTotalCompletionTime = 0.0;
customCompletedTaskSamples = 0;
customCollisionRiskCount = 0;

// Reset smart priority scoring
totalPriorityScore = 0.0;
totalWeightedCompletionTime = 0.0;
totalPriorityWeight = 0.0;

highPriorityTotalTime = 0.0;
highPriorityCompleted = 0;

lowPriorityCompleted = 0;
mediumPriorityCompleted = 0;
emergencyPriorityCompleted = 0;

// Reset completion-time list if you created completionTimes as Main variable
if (completionTimes != null) {
    ArrayList cList = (ArrayList) completionTimes;
    cList.clear();
}

// Reset station capacity counters
for (int i = 0; i < pickupActive.length; i++) {
    pickupActive[i] = 0;
}

int n = robots.size();

for (int i = 0; i < n; i++) {
    Robot r = (Robot) robots.get(i);

    r.id = i;
    r.batteryLevel = 100.0;
    r.currentTask = null;
    r.isPickedUp = false;
    r.isYielding = false;
    r.tasksCompleted = 0;

    // Reset RL variables
    r.lastState = 0;
    r.lastAction = 0;
    r.hasLastAction = false;
    r.wantsCharging = false;
    r.lastCollisionRiskTime = -999;

    // Optional: reset Q-table for a clean comparison run
    for (int s = 0; s < 18; s++) {
        r.qTable[s][0] = 0.0;   // WORK
        r.qTable[s][1] = 0.0;   // CHARGE
    }

    // Spawn robots inside/around yellow charging station centered at (480,245)
    double spawnX;
    double spawnY;

    if (i == 0) {
        spawnX = 465;
        spawnY = 235;
    } else if (i == 1) {
        spawnX = 480;
        spawnY = 235;
    } else if (i == 2) {
        spawnX = 495;
        spawnY = 235;
    } else if (i == 3) {
        spawnX = 472;
        spawnY = 255;
    } else {
        spawnX = 488;
        spawnY = 255;
    }

    r.jumpTo(spawnX, spawnY);
    r.targetX = spawnX;
    r.targetY = spawnY;

    r.setSpeed(p_robotSpeed);

    traceln("Robot " + i + " spawned inside charging station at ("
        + (int) spawnX + ", " + (int) spawnY + ")");
}

traceln("Hospital layout initialized with " + stList.size() + " locations.");
traceln("0-2 Pharmacy | 3-5 Lab | 6-8 Ward A | 9-11 Ward B | 12 Charging");
traceln("KPI, priority scoring, task queue, pickup counters, and robot RL states reset.");]]></StartupCode>
