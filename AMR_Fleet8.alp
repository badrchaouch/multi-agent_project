	<JavaClasses>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1781771907495</Id>
			<Name><![CDATA[Task]]></Name>
			<Text><![CDATA[public class Task {

    public int id;

    public double pickupX;
    public double pickupY;

    public double dropoffX;
    public double dropoffY;

    public int priority;

    public int pickupIndex;
    public int dropoffIndex;

    public String sourceLocation;
    public String destLocation;

    public boolean assigned = false;
    public String status = "UNASSIGNED";

    public double createdAt;
    public double completedAt = -1.0;

    public Task(
        int id,
        String sourceLocation,
        double pickupX,
        double pickupY,
        String destLocation,
        double dropoffX,
        double dropoffY,
        int priority,
        int pickupIndex,
        int dropoffIndex,
        double createdAt
    ) {
        this.id = id;

        this.sourceLocation = sourceLocation;
        this.pickupX = pickupX;
        this.pickupY = pickupY;

        this.destLocation = destLocation;
        this.dropoffX = dropoffX;
        this.dropoffY = dropoffY;

        this.priority = clampPriority(priority);
        this.pickupIndex = pickupIndex;
        this.dropoffIndex = dropoffIndex;

        this.createdAt = createdAt;
        this.assigned = false;
        this.status = "UNASSIGNED";
    }

    private int clampPriority(int p) {
        if (p < 1) return 1;
        if (p > 3) return 3;
        return p;
    }

    public int getPriorityValue() {
        return priority;
    }

    public String getPriorityName() {
        if (priority == 3) return "EMERGENCY";
        if (priority == 2) return "MEDIUM";
        return "LOW";
    }

    public String toString() {
        return "Task#" + id
            + " [" + getPriorityName() + "] "
            + sourceLocation + "(" + (int)pickupX + "," + (int)pickupY + ")"
            + " -> "
            + destLocation + "(" + (int)dropoffX + "," + (int)dropoffY + ")"
            + " status=" + status;
    }
}]]></Text>
		</JavaClass>
	</JavaClasses>
